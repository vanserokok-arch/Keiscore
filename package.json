{
  "name": "keiscore",
  "version": "1.0.0",
  "description": "KEIScore OCR core bootstrap foundation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "sandbox:build:renderer": "vite build -c vite.sandbox.config.ts",
    "sandbox:build:preload": "mkdir -p dist-sandbox/src/main && cp src/main/preload.cjs dist-sandbox/src/main/preload.cjs",
    "sandbox:build:main": "tsc -p tsconfig.sandbox.json && npm run sandbox:build:preload",
    "sandbox:start": "npm run build && npm run sandbox:build:renderer && npm run sandbox:build:main && electron dist-sandbox/src/main/main.js",
    "visual:smoke": "npm run build && node scripts/visual-smoke-runner.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "execa": "^9.6.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.5",
    "which": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/node": "^25.3.2",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.3.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.5",
    "vitest": "^4.0.18"
  }
}
